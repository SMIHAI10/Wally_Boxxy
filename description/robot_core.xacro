<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="base_link">
    </link>

    <joint name="base_link_joint" type="fixed">
        <parent link="base_link" />
        <child link="chassis" />
        <origin xyz="-0.15 0 0.035" rpy="0 0 0" />
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0.15 0 0.05" rpy="0 0 0" />
            <geometry>
                <box size="0.3 0.2 0.1" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <origin xyz="0.15 0 0.05" rpy="0 0 0" />
            <geometry>
                <box size="0.3 0.2 0.1" />
            </geometry>
        </collision>
        <xacro:box_inertia m="5" x="0.3" y="0.2" z="0.1" o_xyz="0.15 0 0.05" o_rpy="0 0 0" />
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="chassis" />
        <child link="left_wheel" />
        <origin xyz="0.06 0.12 0.02" rpy="-${pi/2} 0 0" />
        <axis xyz="0 0 1" />
    </joint>

    <link name="left_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.04" radius="0.055" />
            </geometry>
            <material name="purple" />
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.04" radius="0.055" />
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="0.1" r="0.055" l="0.04" o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="chassis" />
        <child link="right_wheel" />
        <origin xyz="0.06 -0.12 0.02" rpy="${pi/2} 0 0" />
        <axis xyz="0 0 1" />
    </joint>

    <link name="right_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.04" radius="0.055" />
            </geometry>
            <material name="purple" />
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.04" radius="0.055" />
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="0.1" r="0.055" l="0.04" o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>

    <joint name="caster_wheel_joint" type="fixed">
        <parent link="chassis" />
        <child link="caster_wheel" />
        <origin xyz="0.25 0 0" rpy="0 0 0" />
    </joint>

    <link name="caster_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <sphere radius="0.035" />
            </geometry>
            <material name="orange" />
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <sphere radius="0.035" />
            </geometry>
        </collision>
        <xacro:sphere_inertia m="0.1" r="0.035" o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>

    <joint name="laser_joint" type="fixed">
        <parent link="chassis" />
        <child link="laser_frame" />
        <origin xyz="0.2 0 0.1" rpy="0 0 0" />
    </joint>

    <link name="laser_frame">
        <visual>
            <origin xyz="0 0 0.025" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.05" radius="0.05" />
            </geometry>
            <material name="red" />
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.05" radius="0.05" />
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="0.1" r="0.05" l="0.05" o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>

    <gazebo reference="laser_frame">
        <sensor name="laser" type="lidar">
            <pose>0 0 0 0 0 0</pose>
            <update_rate>10</update_rate>
            <visualize>true</visualize>
            <always_on>true</always_on>
            <!-- Tell gz-sim where to publish -->
            <topic>/model/wally_boxxy/scan</topic>
            <ray>
                <scan>
                    <horizontal>
                    <samples>360</samples>
                    <resolution>1</resolution>
                    <min_angle>-3.14159</min_angle>
                    <max_angle>3.14159</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.3</min>
                    <max>12</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </ray>
        </sensor>
    </gazebo>




</robot>